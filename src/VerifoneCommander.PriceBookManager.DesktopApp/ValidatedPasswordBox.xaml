<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VerifoneCommander.PriceBookManager.DesktopApp.ValidatedPasswordBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VerifoneCommander.PriceBookManager.DesktopApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel>
        <PasswordBox Header="{x:Bind Header, Mode=OneWay}"
                     PlaceholderText="{x:Bind Placeholder, Mode=OneWay}"
                     IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                     Password="{x:Bind Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Name="ErrorTextBlock"
                   Text="{x:Bind Error, Mode=OneWay}"
                   Foreground="DarkRed"
                   TextWrapping="WrapWholeWords" />
    </StackPanel>
</UserControl>
