<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VerifoneCommander.PriceBookManager.DesktopApp.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VerifoneCommander.PriceBookManager.DesktopApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style TargetType="local:ValidatedTextBox">
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style TargetType="local:ValidatedPasswordBox">
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </Page.Resources>

    <StackPanel>
        <local:ValidatedTextBox Header="Username"
                                Placeholder="Enter your username"
                                Text="{x:Bind ViewModel.Username.Text, Mode=TwoWay}"
                                Error="{x:Bind ViewModel.Username.Error, Mode=OneWay}" />
        <local:ValidatedPasswordBox Header="Password"
                                Placeholder="Enter your password"
                                Password="{x:Bind ViewModel.Password.Text, Mode=TwoWay}"
                                Error="{x:Bind ViewModel.Password.Error, Mode=OneWay}" />
    </StackPanel>
</Page>
